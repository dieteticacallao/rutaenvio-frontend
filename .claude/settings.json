{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git *)",
      "Read",
      "Write",
      "Write(.claude/rules/**)",
      "Edit",
      "Edit(.claude/rules/**)",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
